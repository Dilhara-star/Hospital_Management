# Copy this file to .env and fill in your real Brevo details.
# .env is in .gitignore, so it is never committed - .env.example is just a template.

# API key from Brevo > SMTP & API > API Keys
BREVO_API_KEY=your-brevo-api-key-here

# The "from" address for confirmation emails - must be a verified sender in Brevo
BREVO_SENDER_EMAIL=your-verified-sender@example.com

# The "from" name shown to the patient
BREVO_SENDER_NAME=City Hospital
